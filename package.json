{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hotel-concierge-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hotel-concierge-db --remote",
    "cf-typegen": "wrangler types",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "hono": "^4.12.27",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.2",
    "@cloudflare/workers-types": "^4.20260624.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "fast-xml-parser": "^5.9.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.104.0"
  }
}
